# 复制为 .env.local 后填入实际值

# ─── AI 推理（OpenAI 兼容协议，任选一家）───
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key

# ─── 或用其他 OpenAI 兼容模型 ───
# AI_PROVIDER=mimo
# MIMO_API_KEY=your-api-key
# MIMO_BASE_URL=https://your-provider/v1
# MIMO_MODEL=model-name

# ─── 站点 ───
NEXT_PUBLIC_SITE_URL=http://localhost:3100

# AI 免费用户每日解读额度（默认 3 次，北京时间 0 点重置；与合盘共用）
# AI_FREE_DAILY_QUOTA=3
# AI 专业版每日解读额度（默认 20 次）
# AI_PRO_DAILY_QUOTA=20

# 合盘每日免费次数（默认 3 次，与解读共用额度池）
# HEMING_FREE_DAILY_QUOTA=3
# HEMING_PRO_DAILY_QUOTA=20

# ─── 登录（本地开发）───
# 会话签名密钥（生产环境务必更换）
# AUTH_SECRET=your-random-secret
# AUTH_DEV_MODE=1  # 开发模式会在 API 响应中返回 devCode 验证码，无需真实短信/邮件
