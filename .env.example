# 复制为 .env.local 后填入实际值

# ─── AI 推理（OpenAI 兼容协议，任选一家）───
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key

# ─── 或用其他 OpenAI 兼容模型 ───
# AI_PROVIDER=mimo
# MIMO_API_KEY=your-api-key
# MIMO_BASE_URL=https://your-provider/v1
# MIMO_MODEL=model-name

# ─── 站点 ───
NEXT_PUBLIC_SITE_URL=http://localhost:3100

# AI 免费用户每日解读额度（默认 10 次，北京时间 0 点重置）
# AI_FREE_DAILY_QUOTA=10

# 合盘每日免费次数（默认 10 次，北京时间 0 点重置）
# HEMING_FREE_DAILY_QUOTA=10
